<%- include('partials/header', { title: 'Manage Requests' }) %>
<%- include('partials/navbar') %>

<div class="container-fluid">
  <div class="row">
    <div class="col-md-2 p-0"><%- include('partials/sidebar') %></div>
    <div class="col-md-10 page-wrap">
      <h2 class="mb-4">Clearance Requests</h2>

      <div class="card shadow-sm">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-bordered align-middle">
              <thead class="table-light">
                <tr>
                  <th>Student</th>
                  <th>Email</th>
                  <th>Checkpoint</th>
                  <th>Status</th>
                  <th>Remarks</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% requests.forEach((r) => { %>
                  <tr>
                    <td><%= r.fullname %></td>
                    <td><%= r.email %></td>
                    <td><%= r.checkpoint_name %></td>
                    <td><%= r.status %></td>
                    <td><%= r.remarks || '-' %></td>
                    <td>
                      <form method="POST" action="/admin/requests/<%= r.id %>/status" class="d-flex gap-2">
                        <select name="status" class="form-select form-select-sm" style="width: 120px;">
                          <option value="pending" <%= r.status === 'pending' ? 'selected' : '' %>>Pending</option>
                          <option value="approved" <%= r.status === 'approved' ? 'selected' : '' %>>Approved</option>
                          <option value="rejected" <%= r.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                        </select>
                        <input type="text" name="remarks" class="form-control form-control-sm" placeholder="Remarks" value="<%= r.remarks || '' %>">
                        <button class="btn btn-primary btn-sm">Update</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>