<%- include('partials/header', { title: 'Clearance Slip' }) %>
<%- include('partials/navbar') %>

<div class="container-fluid">
  <div class="row">
    <div class="col-md-2 p-0"><%- include('partials/sidebar') %></div>
    <div class="col-md-10 page-wrap">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Clearance Slip</h2>
        <button class="btn btn-outline-primary" onclick="window.print()">Print</button>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <h4><%= student.fullname %></h4>
          <p class="mb-4"><strong>Email:</strong> <%= student.email %></p>

          <table class="table table-bordered">
            <thead class="table-light">
              <tr>
                <th>Checkpoint</th>
                <th>Status</th>
                <th>Remarks</th>
                <th>Updated</th>
              </tr>
            </thead>
            <tbody>
              <% requests.forEach((r) => { %>
                <tr>
                  <td><%= r.checkpoint_name %></td>
                  <td><%= r.status %></td>
                  <td><%= r.remarks || '-' %></td>
                  <td><%= r.updated_at %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>